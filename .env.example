# ─── Required ──────────────────────────────────────────────────────────────
# YouTube Data API key — https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 in your project first.
YOUTUBE_API_KEY=your_key_here

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ─── Server ────────────────────────────────────────────────────────────────
# API key the frontend must send in X-API-Key header (must match Vercel's VITE_API_KEY)
API_KEY=change-me-to-a-random-string

# Public URL where the VPS server is reachable (for tunnel discovery)
# e.g. http://YOUR_VPS_IP:8080 or your Cloudflare tunnel URL
VPS_IP=http://localhost:8080
